# ─── FayeTradeX Backend ──────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Admin credentials (single-user v1)
ADMIN_USERNAME=admin
ADMIN_PIN=changeme

# JWT signing secret (use a long random string in production)
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_SECRET_STRING
SESSION_TTL=8h

# MT5 Bridge URL (Python bridge running on Windows machine)
MT5_BRIDGE_URL=http://localhost:8765

# Optional: shared secret between backend and bridge (set same in bridge .env)
MT5_BRIDGE_SECRET=

# Magic number for MT5 orders (used to identify FayeTradeX orders)
MT5_MAGIC=20240001

# Watchlist (comma-separated MT5 symbols)
WATCHLIST=XAUUSD,EURUSD,GBPUSD,US30,NAS100
