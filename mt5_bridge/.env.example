# ─── FayeTradeX MT5 Bridge ──────────────────────────────────────
# Run on the Windows machine where MetaTrader 5 is installed.
# Copy to .env and fill in real values.

# MT5 account
MT5_LOGIN=12345678
MT5_PASSWORD=your_broker_password
MT5_SERVER=ICMarkets-Demo

# Optional: full path to MT5 terminal if auto-detect fails
# MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# Bridge network
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8765

# Optional: shared secret (must match MT5_BRIDGE_SECRET in backend .env)
BRIDGE_SECRET=
